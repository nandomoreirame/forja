{
  "name": "@forja/app",
  "private": true,
  "version": "1.4.6",
  "description": "Desktop GUI client for Vibe Coders and other AI coding CLIs",
  "author": {
    "name": "Fernando Moreira",
    "email": "nandomoreira.me@gmail.com"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm dev:vite\" \"pnpm dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:1420 && tsc -p electron/tsconfig.json && electron dist-electron/main.js",
    "build": "tsc -p electron/tsconfig.json && vite build",
    "build:electron": "pnpm build && electron-builder",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "version:bump": "bash scripts/bump-version.sh",
    "analyze": "ANALYZE=true vite build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.0.0",
    "@fontsource/geist-sans": "^5.0.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.1",
    "electron-store": "^10.0.0",
    "lucide-react": "^0.469.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.5",
    "remark-gfm": "^4.0.1",
    "systeminformation": "^5.23.0",
    "tailwind-merge": "^3.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.0"
  }
}
